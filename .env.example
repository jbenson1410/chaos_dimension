# Required
# App connection. Use the cd_app role (NOBYPASSRLS) so RLS enforces per-user isolation.
DATABASE_URL=postgres://cd_app:pass@host/db
CHAOS_PASSWORD_HASH=$2a$10$replace-me-with-output-from-npm-run-hash-password
CHAOS_SESSION_SECRET=replace-with-output-of-openssl-rand-hex-32
# Email of the owner user. The multi-tenant migration creates the users row with this.
CHAOS_OWNER_EMAIL=you@example.com

# Migrations / DDL. The cd_app role can't ALTER TABLE / CREATE POLICY, so the
# migration script connects as an owner-level role. Falls back to DATABASE_URL
# if unset (fine for a fresh self-host before the two-role split is set up).
DATABASE_URL_MIGRATIONS=postgres://owner:pass@host/db

# Tests. When running under vitest, the DB layer uses these instead of the
# production URLs — point them at a disposable Neon test branch so `npm test`
# never writes to prod. If VITEST is set and TEST_DATABASE_URL is missing,
# the test run fails fast rather than touching the production database.
TEST_DATABASE_URL=postgres://cd_app:pass@test-branch-host/db
TEST_DATABASE_URL_MIGRATIONS=postgres://owner:pass@test-branch-host/db

# Optional
# Set to 'true' on a public deploy (chaosdimension.fyi) to expose the demo landing.
# Leave unset for private forks - / will redirect to /login.
CHAOS_PUBLIC_DEMO=
VITE_PUBLIC_DEMO=
